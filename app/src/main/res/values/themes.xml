<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Fixed warm-dark theme to match the RatherLLM design. Compose draws the UI;
         this only sets the window background (no white flash on launch) and system bars. -->
    <style name="Theme.RatherLLM" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/app_bg</item>
        <item name="android:statusBarColor">@color/app_bg</item>
        <item name="android:navigationBarColor">@color/app_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
